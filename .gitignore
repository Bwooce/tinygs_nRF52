# Ignore everything in parent directory except the app folder itself?
# Standard T2 topology handles this since Zephyr sits *outside* the repo, or we can make the repo an isolated workspace.
ncs/
build_test/
*.log
*.uf2

# MQTT credentials — never commit
src/mqtt_credentials.h

