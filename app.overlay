/*
 * TinyGS application overlay for the Heltec Mesh Node T114.
 *
 * Hardware definitions live in the board files at
 *   boards/heltec/heltec_mesh_node_t114/
 * This overlay only declares application-level wiring:
 *   - USB CDC ACM as the Zephyr console
 *   - A flash-disk node backed by tinygs_storage so USB MSC can serve
 *     the on-device configurator drive
 */

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		/* zephyr,display = &st7789v;  -- enable for LVGL */
	};

	/*
	 * 64 KB FATFS partition exposed to the host as the "TinyGS
	 * Configurator" USB drive. The partition itself is defined in the
	 * board DTS (tinygs_storage at 0xE2000); this node just attaches
	 * the disk-access layer to it.
	 */
	msc_disk0 {
		compatible = "zephyr,flash-disk";
		partition = <&tinygs_storage>;
		disk-name = "NAND";
		cache-size = <4096>;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
